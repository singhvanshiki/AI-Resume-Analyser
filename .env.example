APP_ENV=local
LOG_LEVEL=info
INTERNAL_TOKEN=internal-token

POSTGRES_USER=resume
POSTGRES_PASSWORD=resume_pass
POSTGRES_DB=resume_ai
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://resume:resume_pass@postgres:5432/resume_ai
VECTOR_DIM=1536

REDIS_URL=redis://redis:6379/0

MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=resumes
MINIO_SECURE=false
STORAGE_MODE=minio

JWT_SECRET=local-dev-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=14

OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=openai/gpt-oss-120b:free
OPENROUTER_EMBEDDING_MODEL=openai/text-embedding-3-small
OPENROUTER_TIMEOUT_SECONDS=30

CORS_ORIGINS=["http://localhost:3000","http://localhost:8080"]
NEXT_PUBLIC_API_BASE_URL=/api/v1
RATE_LIMIT_PER_MINUTE=120

AUTH_SERVICE_URL=http://auth-service:8000
RESUME_SERVICE_URL=http://resume-service:8000
ANALYSIS_SERVICE_URL=http://analysis-service:8000
RANKING_SERVICE_URL=http://ranking-service:8000
